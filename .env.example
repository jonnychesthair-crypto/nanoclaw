# Power Glove .env template — populate from a working install or OneCLI vault.
# Values intentionally blank.  Order grouped by purpose, not alphabetic.

# Core
ASSISTANT_NAME=
CONTAINER_IMAGE=
TZ=
ANTHROPIC_MODEL=
CLAUDE_CODE_OAUTH_TOKEN=

# Telegram channel
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_API_ROOT=

# Gmail (per-bot credentials dir; container HOME=/workspace/group)
GMAIL_CREDENTIALS_DIR=

# Calendar (comma-separated IDs; "primary" + any imported feeds)
CALENDAR_IDS=

# Voice transcription (Groq whisper-large-v3-turbo)
GROQ_API_KEY=

# Dropbox (Power Glove only — Jeeves does not have this)
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=
DROPBOX_REFRESH_TOKEN=
DROPBOX_ACCESS_TOKEN=

# Regrid land-records (Power Glove only)
REGRID_API_TOKEN=

# eBay (Power Glove only)
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_REFRESH_TOKEN=
EBAY_USER_TOKEN=
